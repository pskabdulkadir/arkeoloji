# --- ORTAM YAPILANDIRMASI ---
# NODE_ENV: development veya production
NODE_ENV="production"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Configuration (JSON format string or individual parameters)
# E.g., {"apiKey": "...", "authDomain": "...", "projectId": "...", "storageBucket": "...", "messagingSenderId": "...", "appId": "..."}
FIREBASE_CONFIG=""

# Individual Firebase Config Options (Alternative to FIREBASE_CONFIG)
FIREBASE_API_KEY=""
FIREBASE_AUTH_DOMAIN=""
FIREBASE_PROJECT_ID=""
FIREBASE_STORAGE_BUCKET=""
FIREBASE_MESSAGING_SENDER_ID=""
FIREBASE_APP_ID=""
FIREBASE_FIRESTORE_DATABASE_ID=""

# --- E-TİCARET ALTYAPISI (GUMROAD) ---
# ETSY_API_KEY yerine Gumroad kullanıyoruz:
GUMROAD_API_KEY=""

# --- SOSYAL MEDYA PAZARLAMA ---
TWITTER_API_KEY=""
